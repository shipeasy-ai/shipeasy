{
  "name": "@shipeasy/openapi",
  "version": "2.4.0",
  "description": "Shipeasy admin OpenAPI 3.2 spec (hand-authored, single source of truth) + the generated TypeScript client, Zod schemas, and types. Consumed by @shipeasy/cli and @shipeasy/mcp.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipeasy-ai/shipeasy.git",
    "directory": "openapi"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./custom": {
      "types": "./dist/custom.d.ts",
      "default": "./dist/custom.js"
    },
    "./node-context": {
      "types": "./dist/node-context.d.ts",
      "default": "./dist/node-context.js"
    },
    "./codegen": {
      "types": "./src/codegen.ts",
      "default": "./src/codegen.ts"
    },
    "./openapi.yaml": "./openapi.yaml",
    "./openapi.json": "./openapi.json"
  },
  "files": [
    "dist/",
    "openapi.yaml",
    "openapi.json",
    "spec/"
  ],
  "scripts": {
    "lint:spec": "redocly lint spec/openapi.yaml",
    "bundle": "redocly bundle spec/openapi.yaml -o openapi.yaml && redocly bundle spec/openapi.yaml -o openapi.json",
    "gen:sdk": "openapi-ts",
    "gen": "pnpm bundle && pnpm gen:sdk",
    "prebuild": "pnpm gen",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "check:drift": "node scripts/check-drift.mjs"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@redocly/cli": "^2.0.0",
    "@types/node": "^20.19.39",
    "tsup": "^8.3.0",
    "typescript": "^5.7.4",
    "vitest": "^2.1.0",
    "yaml": "^2.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
